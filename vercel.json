{
  "version": 2,
  "public": true,
  "buildCommand": "echo 'Static site'",
  "outputDirectory": ".",
  "routes": [
    {
      "src": "/admin",
      "dest": "/admin.html"
    },
    {
      "src": "/(.*)",
      "dest": "/desktop-kali.html"
    },
    {
      "src": "/(.*)",
      "dest": "/mint-desktop.html"
    },
    {
      "src": "/webdev",
      "dest": "/desktop-webdev.html"
    },
    {
      "src": "/(.*)",
      "dest": "/Boot.html"
    },
    {
      "src": "/(.*)",
      "dest": "/Boot.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
